{
  "name": "@marmarlabs/agentbridge-sdk",
  "version": "0.4.0",
  "description": "SDK for declaring AgentBridge actions and emitting AgentBridge manifests in any JavaScript/TypeScript app.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/marmar9615-cloud/agentbridge-protocol.git",
    "directory": "packages/sdk"
  },
  "homepage": "https://github.com/marmar9615-cloud/agentbridge-protocol",
  "keywords": ["agentbridge", "ai-agents", "mcp", "sdk", "zod"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@marmarlabs/agentbridge-core": "^0.4.0",
    "zod": "^4.3.6",
    "zod-to-json-schema": "^3.23.0"
  }
}
