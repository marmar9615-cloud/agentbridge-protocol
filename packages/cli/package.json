{
  "name": "@marmarlabs/agentbridge-cli",
  "version": "0.2.1",
  "description": "Command-line interface for AgentBridge: scan, validate, init, and generate manifests.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/marmar9615-cloud/agentbridge-protocol.git",
    "directory": "packages/cli"
  },
  "homepage": "https://github.com/marmar9615-cloud/agentbridge-protocol",
  "keywords": ["agentbridge", "cli", "ai-agents", "mcp", "openapi"],
  "type": "module",
