{
  "name": "@marmarlabs/agentbridge-openapi",
  "version": "0.2.2",
  "description": "Convert OpenAPI 3.x documents into AgentBridge manifests.",
  "license": "Apache-2.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/marmar9615-cloud/agentbridge-protocol.git",
    "directory": "packages/openapi"
  },
  "homepage": "https://github.com/marmar9615-cloud/agentbridge-protocol",
  "keywords": ["agentbridge", "openapi", "swagger", "ai-agents", "mcp"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup"
  },
  "dependencies": {
    "@marmarlabs/agentbridge-core": "^0.2.0"
  }
}
